{
  "name": "chat",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "shared",
    "server",
    "client"
  ],
  "scripts": {
    "dev": "concurrently -k -n server,client -c blue,magenta \"npm:dev -w server\" \"npm:dev -w client\"",
    "build": "npm run build -w server && npm run build -w client",
    "start": "npm run start -w server",
    "keygen": "node -e \"console.log(require('crypto').randomBytes(32).toString('base64'))\""
  },
  "devDependencies": {
    "concurrently": "^9.0.1"
  }
}
