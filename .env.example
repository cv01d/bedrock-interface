# Copy this file to `.env` and fill in your values. Do NOT commit your real `.env`.

# Port the API server listens on (Vite dev server proxies /api here)
PORT=3000

# 32-byte key, base64-encoded. Generate one with: npm run keygen
# This encrypts all data at rest (messages, project content, AWS credentials).
# If you lose this key, encrypted data is unrecoverable.
MASTER_KEY=
